[sub_resource type="Shader" id="Shader_ir4cu"]
code = "shader_type canvas_item;
render_mode blend_mix, unshaded;


void fragment() {
// Set alpha to distance from center
	COLOR.a = 1.0 - abs(UV.y - 0.5) * 2.0;

// HSV2RGB
	vec3 c = vec3(UV.x, 0.75, 1.0);
	vec4 K = vec4(1.0, 2.0 / 3.0, 1.0 / 3.0, 3.0);
	vec3 p = abs(fract(c.xxx + K.xyz) * 6.0 - K.www);
	COLOR.rgb = c.z * mix(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y);
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_cotdk"]
