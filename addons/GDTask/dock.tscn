[node name="AddNewAt" type="HBoxContainer" parent="Control/Settings/ScrollContainer/VBoxContainer" unique_id=54633830]
layout_mode = 2
tooltip_text = "Where new tasks are added to.

Bottom: Tasks will be added below all other tasks

Top: Tasks will be added above all other tasks

Below Color: Tasks will be added below the last task
that has a hue lesser than or equal to their color

Above Color: Tasks will be added above the first task
that has a hue greater than or equal to their color

Note: Duplicated tasks will always be added directly
below the task they were duplicated from."

